# Real auth (optional for dev/CI)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Force mock auth when 1 (CI default)
USE_MOCK_AUTH=1

# Base URL for API calls (auto-derived in prod)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# JWT secret for share links
SHARE_JWT_SECRET=replace_with_random_32_bytes
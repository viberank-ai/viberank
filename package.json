{
  "name": "viberank",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "cli": "tsx apps/cli/src/ingestBrand.ts",
    "scrape:google": "tsx packages/scraper/src/googleAI.ts",
    "generate:queries:en": "tsx packages/queries/src/generator.ts",
    "expand:queries": "tsx packages/queries/src/translateDedup.ts",
    "tag:queries": "tsx packages/queries/src/tagger.ts",
    "score:cli": "tsx packages/analysis/src/score.cli.ts",
    "eval": "tsx packages/eval/run.ts",
    "eval:ci": "ANALYSIS_DISABLE_LLM=1 EVAL_TOLERANCE=5 tsx packages/eval/run.ts",
    "eval:rebaseline": "tsx -e \"console.log('Edit packages/eval/golden/samples.json by updating expected scores from current output')\"",
    "scan": "tsx packages/pipeline/src/runScan.ts limit=20 surfaces=google_ai,bing_copilot,perplexity",
    "web:dev": "pnpm -C apps/web dev",
    "web:build": "pnpm -C apps/web build",
    "web:start": "pnpm -C apps/web start",
    "reco:hypotheses": "tsx packages/reco/src/hypotheses.ts",
    "reco:actions": "tsx packages/reco/src/run-actions.ts",
    "reco:prioritize": "ts-node packages/reco/src/prioritize.ts",
    "reco:jsonld": "ts-node packages/reco/src/jsonld.ts",
    "reco:all": "pnpm -w tsx packages/reco/src/hypotheses.ts && pnpm -w tsx packages/reco/src/actions.ts && pnpm -w tsx packages/reco/src/prioritize.ts"
  },
  "bin": {
    "ingest-brand": "apps/cli/src/ingestBrand.ts"
  },
  "packageManager": "pnpm@9.15.9",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^8.0.0",
    "lint-staged": "^16.1.2",
    "pinst": "^3.0.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "openai": "^5.11.0",
    "p-limit": "^6.2.0",
    "playwright": "^1.54.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "vader-sentiment": "^1.1.3",
    "zod": "^4.0.14"
  }
}
